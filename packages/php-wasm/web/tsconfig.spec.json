{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"types": [
			"playwright",
			"vitest/globals",
			"vitest/importMeta",
			"vite/client",
			"node"
		],
		"sourceMap": false
	},
	"include": [
		"playwright.config.ts",
		"vite.playwright.config.ts",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/*.spec.js",
		"src/**/*.spec.jsx",
		"src/**/*.d.ts"
	]
}
