packages/php-wasm/node-builds/*/asyncify/** linguist-generated=true -diff
packages/php-wasm/node-builds/*/jspi/** linguist-generated=true -diff
packages/php-wasm/node/src/test/test-data/ linguist-generated=true
packages/php-wasm/web-builds/*/asyncify/** linguist-generated=true -diff
packages/php-wasm/web-builds/*/jspi/** linguist-generated=true -diff
packages/playground/sync/src/test/wp-* linguist-generated=true
